    "vue-markdown": "^2.2.4",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "@playwright/test": "^1.0.0",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/ui": "^1.0.0",
    "@vue/tsconfig": "^0.5.0",
    "eslint": "^8.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "playwright": "^1.0.0",
