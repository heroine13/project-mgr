# 项目进度管理系统 - 环境配置示例
# 复制此文件为 .env 并填入实际配置值

# ===================
# 基础配置
# ===================
PROJECT_NAME=Project Management System
VERSION=0.1.0
ENVIRONMENT=development  # development, production
API_V1_STR=/api/v1

# ===================
# 安全配置 (生产环境必须修改)
# ===================
SECRET_KEY=your-secret-key-change-in-production-replace-with-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===================
# 数据库配置
# ===================
# SQLite (开发环境)
DATABASE_URL=sqlite:///./project_mgr.db
DATABASE_TYPE=sqlite

# MySQL (生产环境)
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/project_manager
# DATABASE_TYPE=mysql
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your-password
# MYSQL_DATABASE=project_manager

# SQL Server
# DATABASE_URL=mssql+pyodbc://user:password@localhost:1433/project_manager?driver=ODBC+Driver+17+for+SQL+Server
# DATABASE_TYPE=sqlserver

# ===================
# Redis 配置
# ===================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===================
# CORS 配置（逗号分隔字符串）
# 生产环境填写实际域名，如: https://frontend.example.com,https://admin.example.com
# 开发环境可留空或填 * （自动允许所有来源）
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1

# ===================
# 文件上传配置
# ===================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10MB

# ===================
# 邮件服务配置 (SMTP)
# ===================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Project Manager
SMTP_USE_TLS=true

# ===================
# 前端配置
# ===================
FRONTEND_URL=http://localhost:5173

# ===================
# 日志配置
# ===================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
# ===================
# AI 智能助手配置
# ===================
# AI 服务提供商: openai, anthropic, local
AI_PROVIDER=openai

# AI API 密钥 (必需)
# OpenAI: https://platform.openai.com/api-keys
# Anthropic: https://console.anthropic.com/
AI_API_KEY=your-api-key-here

# AI 模型选择
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# Anthropic: claude-3-opus-20240229, claude-3-sonnet-20240229
AI_MODEL=gpt-4

# AI API 代理地址 (可选，用于国内访问)
# 示例: https://api.openai.com/v1 (直接)
# 示例: https://your-proxy.com/v1 (代理)
AI_BASE_URL=
